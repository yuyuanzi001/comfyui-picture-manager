{
  "name": "comfyui-picture-manager",
  "version": "1.1.0",
  "description": "Local desktop app to manage ComfyUI generated images, prompts, and generation parameters",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently -n vite,electron \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "dev:electron": "npm run build:main && npm run build:preload && sleep 3 && electron . --dev",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "start": "npm run build && electron .",
   "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "sql.js": "^1.12.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^4.1.10",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.comfyui.picture-manager",
    "productName": "ComfyUI Picture Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*",
      "node_modules/sql.js/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns",
      "category": "public.app-category.graphics-design"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "resources/icon.png",
      "category": "Graphics"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico"
    }
  }
}
